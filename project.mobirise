            ".container, .container-fluid": {
              "display": "flex",
              "min-height": "75px",
              "padding": "0 32px",
              "flex-wrap": "nowrap",
              "& when not (@collapsed)": {
                "@media (min-width: 992px)": {},
                "& when (@transparent)": {
