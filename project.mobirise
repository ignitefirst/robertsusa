        {
          "_name": "aarticle1",
          "_sourceTheme": "expertm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article1 expertm5\" group=\"Article\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <select title=\"Align\" name=\"contentAlign\">\n            <option value=\"justify-content-start\">Left</option>\n            <option value=\"justify-content-center\" selected>Center</option>\n            <option value=\"justify-content-end\">Right</option>\n        </select>\n        <input type=\"range\" inline title=\"Content Width\" name=\"contentWidth\" min=\"6\" max=\"12\" step=\"1\" value=\"11\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <header>Card Style</header>\n        <input type=\"color\" title=\"Card BG 1\" name=\"cardBg1\" value=\"#0e0533\">\n        <input type=\"color\" title=\"Card BG 2\" name=\"cardBg2\" value=\"#0e0533\">\n        <input type=\"checkbox\" name=\"cardShadow\" title=\"Card Shadow\" checked>\n        <input type=\"color\" title=\"Shadow Color 1\" name=\"shadowColor1\" value=\"#d6ee44\" condition=\"cardShadow\">\n        <input type=\"color\" title=\"Shadow Color 2\" name=\"shadowColor2\" value=\"#f6f420\" condition=\"cardShadow\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\">\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/expertm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/expertm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#212428\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div class=\"container\">\n        <div class=\"row card-row {{contentAlign}}\">\n            <div class=\"item-card col-12 d-flex col-lg-{{contentWidth}}\">\n                <div class=\"item-wrap\" mbr-if=\"showTitle || showText || showSubtitle\">\n                    <div class=\"row text-row align-items-center\">\n                        <div class=\"col-12\">\n                            <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".card-title\"><b>The Importance Of Community And Mentorship</b></h5>\n                            <h5 class=\"card-subtitle mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showSubtitle\" data-app-selector=\".card-subtitle\">\n                                Nulla malesuada pellentesque elit eget gravida cum sociis natoque penatibus.\n                                Tempor commodo ullamcorper a lacus vestibulum sed arcu non odio.\n                            </h5>\n                            <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">Another essential aspect of Susa’s vision of success is the value of community and mentorship. Inventors benefit greatly from the support of experienced professionals who can provide guidance, share insights, and inspire confidence. Under Susa’s leadership, InventHelp fosters a collaborative environment where creators can connect, exchange ideas, and learn from one another. Success is amplified when inventors are not isolated but part of a network that nurtures innovation and reinforces ethical, informed decision-making.\n<br>\n<br></p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)",
              "background-attachment": "fixed",
              "background-repeat": "no-repeat",
              "background-size": "cover",
              "background-position": "center center"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "overflow": "hidden",
            ".item-wrap": {
              "position": "relative",
              "height": "100%",
              "width": "100%",
              "padding": "55px",
              "border-radius": "10px",
              "overflow": "hidden",
              "background": "linear-gradient(145deg, @cardBg1, @cardBg2)",
              "& when (@cardShadow)": {
                "box-shadow": "10px 10px 19px @shadowColor1, -10px -10px 19px @shadowColor2"
              },
              "@media (max-width: 767px)": {
                "padding": "40px"
              },
              "@media (max-width: 575px)": {
                "padding": "35px 25px 35px 25px"
              }
            },
            ".card-title": {
              "color": "#f4f5f7",
              "margin-bottom": "30px",
              "@media (max-width: 767px)": {
                "margin-bottom": "20px"
              }
            },
            ".card-subtitle": {
              "color": "#878e99",
              "margin-bottom": "30px",
              "@media (max-width: 767px)": {
                "margin-bottom": "20px"
              }
            },
            ".card-text": {
              "color": "#ffffff",
              "margin-bottom": "0"
            }
          },
          "_cid": "ujl8SUNL1A",
          "_anchor": "aarticle1-7",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
