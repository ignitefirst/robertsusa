        {
          "_name": "aarticle2",
          "_sourceTheme": "algom5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article2 algom5\" group=\"Article\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"checkbox\" name=\"reverseContent\" title=\"Reverse\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"8\" value=\"6\" step=\"1\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n        <header>Background</header>\n        <input type=\"color\" title=\"Color\" name=\"bgColor\" value=\"#0e0533\">\n    </mbr-parameters>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"main-container\">\n                <div class=\"col-12 col-lg col-title\" mbr-if=\"showTitle || showSubtitle\">\n                    <h5 class=\"mbr-section-title mbr-fonts-style\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\"><div><b>Empowering Inventors Through Shared Accountability</b></div></h5>\n                    <h6 class=\"mbr-section-subtitle mbr-fonts-style\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-5\">\n                        Ultricies mi quis hendrerit dolor magna eget.\n                    </h6>\n                </div>\n                <div class=\"col-md-12 col-lg-{{textWidth}} col-text\">\n                    <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\">One of the most distinctive aspects of Robert Susa’s leadership is how accountability is shared with inventors. Rather than positioning the organization as the sole authority, he encourages inventors to actively engage with their journey, ask questions, and make informed choices.\n<br><br>This shared accountability model respects the intelligence and <a href=\"index.html\" class=\"text-primary\"><b><u>creativity of inventors</u></b></a>. It acknowledges that while professional guidance is valuable, ownership of an idea ultimately rests with the creator. By fostering this balance, Robert helps inventors build confidence alongside competence.<br>\n<br>Empowerment through accountability also reduces dependency. Inventors gain clarity about processes, expectations, and potential paths forward, allowing them to participate meaningfully in decision-making. This collaborative dynamic strengthens outcomes and reinforces trust.&nbsp;<br></p>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "background-color": "@bgColor",
            "& when (@reverseContent)": {
              ".row": {
                "flex-direction": "row-reverse"
              }
            },
            ".main-container": {
              "display": "flex",
              "align-items": "stretch",
              "justify-content": "center",
              "padding": "0",
              "@media (max-width: 991px)": {
                "flex-wrap": "wrap",
                "padding": "0 40px"
              }
            },
            ".col-title, .col-text": {
              "display": "flex",
              "flex-direction": "column",
              "align-items": "stretch",
              "justify-content": "center",
              "padding": "10px"
            },
            ".mbr-section-title": {
              "color": "#ffffff",
              "margin-bottom": "0 !important",
              "@media (max-width: 767px)": {
                "text-align": "center !important"
              }
            },
            ".mbr-section-subtitle": {
              "color": "#112B6D",
              "margin-bottom": "0 !important",
              "margin-top": "20px",
              "@media (max-width: 767px)": {
                "text-align": "center !important"
              }
            },
            ".mbr-text": {
              "color": "#ffffff",
              "margin-bottom": "0.9rem !important",
              "@media (max-width: 767px)": {
                "text-align": "center !important"
              }
            }
          },
          "_cid": "v9v2DqXHbz",
          "_protectedParams": [],
