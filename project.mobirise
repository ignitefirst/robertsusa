        {
          "_name": "list02",
          "_sourceTheme": "agentm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"list02 agentm5\" group=\"List\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"color\" title=\"Border Color\" value=\"#f6f420\" name=\"border\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/agentm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#0e0533\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/agentm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12 card\">\n                <div class=\"content-wrapper\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n                    <div class=\"title-wrapper\" mbr-if=\"showTitle\">\n                        <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\"><b>Robert Susa</b></h2>\n                    </div>\n                    <div class=\"list-wrapper\">\n                        <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list, .item-wrap\" data-multiline mbr-article>\n                            <li class=\"item-wrap\"><a href=\"leadership-approach.html#article03-66\" class=\"text-primary\">Robert Susa: Inspiring Innovation Everywhere</a></li><li class=\"item-wrap\"><a href=\"leadership-approach.html#content5-67\" class=\"text-primary\">Transparency As An Expression Of Accountability</a></li><a href=\"leadership-approach.html#content5-67\" class=\"text-primary\">\n                            </a><li class=\"item-wrap\"><a href=\"leadership-approach.html#article04-68\" class=\"text-primary\">Accountability In Organizational Culture And Team Leadership</a></li><a href=\"leadership-approach.html#article04-68\" class=\"text-primary\">\n                            </a><li class=\"item-wrap\"><a href=\"leadership-approach.html#article01-69\" class=\"text-primary\">Ethical Decision-Making Guided By Accountability</a></li><a href=\"leadership-approach.html#article01-69\" class=\"text-primary\">\n                            </a><li class=\"item-wrap\"><a href=\"leadership-approach.html#aarticle2-6a\" class=\"text-primary\">Empowering Inventors Through Shared Accountability</a></li><a href=\"leadership-approach.html#aarticle2-6a\" class=\"text-primary\">\n                            </a><li class=\"item-wrap\"><a href=\"leadership-approach.html#aarticle1-6b\" class=\"text-primary\">Leadership Accountability And Long-Term Trust</a></li>\n                        </ul>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
