          "_cid": "v9v2Ez6dBK",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {},
          "_anchor": "article01-6v"
        },
        {
          "_name": "aarticle2",
          "_sourceTheme": "algom5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article2 algom5\" group=\"Article\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"checkbox\" name=\"reverseContent\" title=\"Reverse\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"8\" value=\"6\" step=\"1\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n        <header>Background</header>\n        <input type=\"color\" title=\"Color\" name=\"bgColor\" value=\"#0e0533\">\n    </mbr-parameters>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"main-container\">\n                <div class=\"col-12 col-lg col-title\" mbr-if=\"showTitle || showSubtitle\">\n                    <h5 class=\"mbr-section-title mbr-fonts-style\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\"><div><b>Preparing Inventors For Real-World Decision Making\n</b></div><div><b><br></b></div></h5>\n                    <h6 class=\"mbr-section-subtitle mbr-fonts-style\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-5\">\n                        Ultricies mi quis hendrerit dolor magna eget.\n                    </h6>\n                </div>\n                <div class=\"col-md-12 col-lg-{{textWidth}} col-text\">\n                    <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\">Execution often involves complex decisions that cannot be undone easily. Robert Susa emphasizes education because it prepares inventors for the realities of those choices. Understanding timelines, potential outcomes, and industry norms allows inventors to approach execution with realistic expectations.<br>\n<br>This preparation reduces disappointment and builds resilience. When inventors know what to expect, they are better equipped to adapt and stay motivated. Robert Susa’s focus on education ensures that execution is grounded in awareness rather than assumptions.&nbsp;<br></p>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "background-color": "@bgColor",
            "& when (@reverseContent)": {
              ".row": {
                "flex-direction": "row-reverse"
              }
            },
            ".main-container": {
              "display": "flex",
              "align-items": "stretch",
              "justify-content": "center",
              "padding": "0",
              "@media (max-width: 991px)": {
                "flex-wrap": "wrap",
                "padding": "0 40px"
              }
            },
            ".col-title, .col-text": {
              "display": "flex",
              "flex-direction": "column",
              "align-items": "stretch",
              "justify-content": "center",
              "padding": "10px"
            },
            ".mbr-section-title": {
              "color": "#ffffff",
              "margin-bottom": "0 !important",
              "@media (max-width: 767px)": {
                "text-align": "center !important"
              }
            },
            ".mbr-section-subtitle": {
              "color": "#112B6D",
              "margin-bottom": "0 !important",
              "margin-top": "20px",
              "@media (max-width: 767px)": {
                "text-align": "center !important"
              }
            },
            ".mbr-text": {
              "color": "#ffffff",
              "margin-bottom": "0.9rem !important",
              "@media (max-width: 767px)": {
                "text-align": "center !important"
              }
            }
          },
          "_cid": "v9v2EAmlWI",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {},
          "_anchor": "aarticle2-6w"
        },
        {
          "_name": "aarticle1",
          "_sourceTheme": "expertm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article1 expertm5\" group=\"Article\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <select title=\"Align\" name=\"contentAlign\">\n            <option value=\"justify-content-start\">Left</option>\n            <option value=\"justify-content-center\" selected>Center</option>\n            <option value=\"justify-content-end\">Right</option>\n        </select>\n        <input type=\"range\" inline title=\"Content Width\" name=\"contentWidth\" min=\"6\" max=\"12\" step=\"1\" value=\"11\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <header>Card Style</header>\n        <input type=\"color\" title=\"Card BG 1\" name=\"cardBg1\" value=\"#0e0533\">\n        <input type=\"color\" title=\"Card BG 2\" name=\"cardBg2\" value=\"#0e0533\">\n        <input type=\"checkbox\" name=\"cardShadow\" title=\"Card Shadow\" checked>\n        <input type=\"color\" title=\"Shadow Color 1\" name=\"shadowColor1\" value=\"#d6ee44\" condition=\"cardShadow\">\n        <input type=\"color\" title=\"Shadow Color 2\" name=\"shadowColor2\" value=\"#f6f420\" condition=\"cardShadow\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\">\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/expertm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/expertm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#212428\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div class=\"container\">\n        <div class=\"row card-row {{contentAlign}}\">\n            <div class=\"item-card col-12 d-flex col-lg-{{contentWidth}}\">\n                <div class=\"item-wrap\" mbr-if=\"showTitle || showText || showSubtitle\">\n                    <div class=\"row text-row align-items-center\">\n                        <div class=\"col-12\">\n                            <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".card-title\"><b>Mentorship As A Natural Extension Of Education</b></h5>\n                            <h5 class=\"card-subtitle mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showSubtitle\" data-app-selector=\".card-subtitle\">\n                                Nulla malesuada pellentesque elit eget gravida cum sociis natoque penatibus.\n                                Tempor commodo ullamcorper a lacus vestibulum sed arcu non odio.\n                            </h5>\n                            <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">Education, for Robert Susa, extends beyond information—it includes mentorship. Guidance, encouragement, and perspective are essential components of learning. Through mentorship, inventors gain insights that cannot be found in manuals or checklists.<br>\n<br>Robert Susa’s commitment to mentorship reflects his belief that innovation thrives in environments of honesty and shared purpose. By combining education with human connection, he helps inventors feel supported as individuals, not just as idea-holders.\n<br>\n<br></p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)",
              "background-attachment": "fixed",
              "background-repeat": "no-repeat",
              "background-size": "cover",
              "background-position": "center center"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "overflow": "hidden",
            ".item-wrap": {
              "position": "relative",
              "height": "100%",
              "width": "100%",
              "padding": "55px",
              "border-radius": "10px",
              "overflow": "hidden",
              "background": "linear-gradient(145deg, @cardBg1, @cardBg2)",
              "& when (@cardShadow)": {
                "box-shadow": "10px 10px 19px @shadowColor1, -10px -10px 19px @shadowColor2"
              },
              "@media (max-width: 767px)": {
                "padding": "40px"
              },
              "@media (max-width: 575px)": {
                "padding": "35px 25px 35px 25px"
              }
            },
            ".card-title": {
              "color": "#f4f5f7",
              "margin-bottom": "30px",
              "@media (max-width: 767px)": {
                "margin-bottom": "20px"
              }
            },
            ".card-subtitle": {
              "color": "#878e99",
              "margin-bottom": "30px",
              "@media (max-width: 767px)": {
                "margin-bottom": "20px"
              }
            },
            ".card-text": {
              "color": "#ffffff",
              "margin-bottom": "0"
            }
          },
          "_cid": "v9v2EBuK5C",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {},
          "_anchor": "aarticle1-6x"
        },
        {
          "_name": "alist2",
          "_sourceTheme": "orderm5",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value",
              ".second-bg-color": {
                "position": "absolute",
                "top": "0",
                "left": "0",
                "width": "100%",
                "height": "100%",
                "background-color": "@secondColor",
                "border-top-left-radius": "4.1666666667vw",
                "border-top-right-radius": "4.1666666667vw"
              }
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "position": "relative",
            "& when (@reverseContent)": {
              ".row": {
                "flex-direction": "row-reverse"
              }
            },
            ".col-title": {
              "@media (max-width: 991px)": {
                "margin-bottom": "7vw"
              },
              "@media (max-width: 767px)": {
                "margin-bottom": "9vw"
              }
            },
            ".mbr-section-title": {
              "color": "#000000",
              "margin-bottom": "1rem"
            },
            ".mbr-section-subtitle": {
              "color": "#FFFFFF",
              "margin-bottom": "0"
            },
            ".toggle-panel": {
              "& when (@showListBorder)": {
                "border-top": "1px solid @listBorderColor"
              }
            },
            ".card": {
              "padding-bottom": "0",
              "border-radius": "0",
              "& when (@showListBorder)": {
                "border-bottom": "1px solid @listBorderColor"
              }
            },
            ".card-header": {
              "background-color": "transparent",
              "margin-bottom": "0",
              "padding": "0",
              "border-bottom": "none !important"
            },
            ".sign": {
              "font-family": "'Moririse2' !important",
              "padding": "10px",
              "font-size": "18px",
              "border-radius": "50%",
              "color": "@listIconColor",
              "border": "1px solid @listIconColor",
              "transition": "0.3s all",
              "animation": "icon-move-out 0.2s ease-out",
              "@media (max-width: 991px)": {
                "display": "flex",
                "align-items": "center",
                "justify-content": "center",
                "flex-shrink": "0",
                "padding": "0",
                "width": "7.3vw",
                "font-size": "3.7vw",
                "aspect-ratio": "(1 / 1)"
              },
              "@media (max-width: 767px)": {
                "width": "8.53vw",
                "font-size": "4.3vw"
              }
            },
            ".panel-title-edit": {
              "color": "#000000",
              "padding-right": "1rem",
              "transition": ".3s all"
            },
            ".panel-title": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "space-between",
              "padding": "36px 0",
              "transition": ".4s all",
              "@media (max-width: 991px)": {
                "padding": "5vw 0"
              },
              "@media (max-width: 767px)": {
                "padding": "6.4vw 0"
              },
              "&[aria-expanded=\"false\"]": {
                ".sign": {
                  "&:hover": {
                    "animation": "icon-move 0.8s forwards"
                  }
                }
              },
              "&[aria-expanded=\"true\"]": {
                ".sign": {
                  "transform": "rotate(135deg)"
                }
              }
            },
            ".panel-text": {
              "color": "#000000",
              "margin-bottom": "36px",
              "max-width": "80%",
              "width": "100%",
              "@media (max-width: 991px)": {
                "margin-bottom": "5vw",
                "max-width": "100%"
              },
              "@media (max-width: 767px)": {
                "margin-bottom": "6.4vw"
              }
            },
            "@keyframes icon-move": {
              "0%": {
                "transform": "translate3d(0, 0%, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0deg) skew(0deg, 0deg)",
                "will-change": "transform"
              },
              "80%": {
                "transform": "translate3d(0, 0%, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(360deg) skew(0deg, 0deg)"
              },
              "100%": {
                "transform": "translate3d(0, 0%, 0px) scale3d(1.2, 1.2, 1) rotateX(0deg) rotateY(0deg) rotateZ(360deg) skew(0deg, 0deg)",
                "will-change": "auto"
              }
            },
            "@keyframes icon-move-out": {
              "0%": {
                "transform": "translate3d(0, 0%, 0px) scale3d(1.2, 1.2, 1) rotateX(0deg) rotateY(0deg) rotateZ(0) skew(0deg, 0deg)",
                "will-change": "transform"
              },
              "100%": {
                "transform": "translate3d(0, 0%, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0) skew(0deg, 0deg)",
                "will-change": "auto"
              }
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"list2 orderm5\" group=\"List\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background':bg.parallax}\" plugins=\"mbr-switch-arrow, mobirise-icons2\">\n\n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"List Width\" name=\"textWidth\" min=\"5\" max=\"8\" step=\"1\" value=\"6\">\n        <input type=\"checkbox\" name=\"reverseContent\" title=\"Reverse\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n        <header>List</header>\n        <input type=\"checkbox\" title=\"Border\" name=\"showListBorder\" checked>\n        <input type=\"color\" title=\"Border Color\" name=\"listBorderColor\" value=\"#000000\" condition=\"showListBorder\">\n        <input type=\"checkbox\" title=\"Icon\" name=\"showListIcon\" checked>\n        <input type=\"color\" title=\"Icon Color\" name=\"listIconColor\" value=\"#FFFFFF\" condition=\"showListIcon\">\n        <select title=\"Amount\" name=\"cardAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\" selected>5</option>\n            <option value=\"6\">6</option>\n        </select>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/background3.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ede7e2\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@PROJECT_PATH@/assets/images/background3.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Second Bg Color\" name=\"secondBgColor\" condition=\"bg.type === 'color'\" checked>\n        <input type=\"color\" title=\"Second Color\" name=\"secondColor\" value=\"#ffffff\" condition=\"secondBgColor && bg.type === 'color'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" checked condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ede7e2\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.9\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div class=\"second-bg-color\" mbr-if=\"secondBgColor\"></div>\n    <div class=\"container\">\n            <div class=\"row justify-content-center\">\n                <div class=\"col-12 col-lg col-title\" mbr-if=\"showTitle || showSubtitle\">\n                    <h5 class=\"mbr-section-title mbr-fonts-style\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\"><b>Frequently Asked Questions?\n                    </b></h5>\n                    <h6 class=\"mbr-section-subtitle mbr-fonts-style\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-4\">\n                        Diam quam nulla porttitor massa id neque. Cursus turpis massa tincidunt dui ut ornare\n                        lectus sit amet.\n                    </h6>\n                </div>\n\n                <div class=\"col-md-12 col-lg-{{textWidth}}\">\n                    <div id=\"bootstrap-toggle\" class=\"toggle-panel accordionStyles tab-content\">\n                        <div class=\"card mb-0\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingOne\">\n                                <a role=\"button\" class=\"collapsed panel-title text-black\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse1\" aria-expanded=\"false\" aria-controls=\"collapse1\">\n                                    <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">What is Robert Susa’s philosophy on inventor success?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\" mbr-if=\"showListIcon\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse1\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingOne\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Robert Susa believes success is defined by empowerment, education, ethical practice, and the ability to transform ideas into real-world solutions.&nbsp;<br></p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card mb-0\" mbr-if=\"cardAmount > 1\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingTwo\">\n                                <a role=\"button\" class=\"collapsed panel-title text-black\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse2\" aria-expanded=\"false\" aria-controls=\"collapse2\">\n                                    <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">Does financial gain define success according to Susa?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\" mbr-if=\"showListIcon\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse2\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingTwo\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">No, Susa emphasizes that true success combines creativity, informed decision-making, and sustainable growth, not just monetary results.&nbsp;<br></p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card mb-0\" mbr-if=\"cardAmount > 2\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingThree\">\n                                <a role=\"button\" class=\"collapsed panel-title text-black\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse3\" aria-expanded=\"false\" aria-controls=\"collapse3\">\n                                    <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">How does InventHelp support inventors under Susa’s leadership?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\" mbr-if=\"showListIcon\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse3\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingThree\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">InventHelp provides structured guidance, including patent referrals, prototype modeling, marketing materials, and strategic presentation preparation.&nbsp;<br></p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card mb-0\" mbr-if=\"cardAmount > 3\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingFour\">\n                                <a role=\"button\" class=\"collapsed panel-title text-black\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse4\" aria-expanded=\"false\" aria-controls=\"collapse4\">\n                                    <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">Why is transparency important in Susa’s definition of success?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\" mbr-if=\"showListIcon\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse4\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFour\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Transparency fosters confidence, trust, and clarity, enabling inventors to make well-informed decisions throughout their invention journey.&nbsp;<br></p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card mb-0\" mbr-if=\"cardAmount > 4\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingFive\">\n                                <a role=\"button\" class=\"collapsed panel-title text-black\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse5\" aria-expanded=\"false\" aria-controls=\"collapse5\">\n                                    <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">Can inventors succeed without mentorship according to Susa?\n<div><br></div></h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\" mbr-if=\"showListIcon\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse5\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFive\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">While individual effort is important, Susa highlights the role of mentorship and community in guiding inventors toward ethical, informed, and meaningful achievements.&nbsp;<br></p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card mb-0\" mbr-if=\"cardAmount > 5\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingSix\">\n                                <a role=\"button\" class=\"collapsed panel-title text-black\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse6\" aria-expanded=\"false\" aria-controls=\"collapse6\">\n                                    <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">\n                                        PURUS NON ENIM?\n                                    </h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\" mbr-if=\"showListIcon\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse6\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingSix\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                        Erat imperdiet sed euismod nisi porta lorem mollis. Arcu vitae\n                                        elementum curabitur vitae nunc sed. Magna fermentum iaculis eu non diam. Magna\n                                        etiam tempor orci eu lobortis.\n                                    </p>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n</section>",
          "_anchor": "alist2-72",
          "_isUserblock": true,
          "_cid": "v9vntiyOzo",
