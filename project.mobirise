                    "@media (max-width: 992px)": {
                      "width": "100%"
                    }
                  }
                },
                ".links-wrapper": {
                  ".mbr-section-btn": {
                    "margin-top": "30px",
                    "gap": "20px 0",
                    "display": "inline-flex",
                    "flex-wrap": "wrap",
