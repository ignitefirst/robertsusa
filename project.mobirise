                  "padding": "0"
                }
              }
            },
            ".container": {
              "@media (max-width: 992px)": {
                "padding": "0 20px"
              }
            },
            ".title-wrapper": {
              ".logo-wrap": {
                "margin-bottom": "30px",
                "@media (max-width: 768px)": {
                  "margin-bottom": "16px"
                },
                "img": {
                  "display": "inline-flex",
                  "width": "70px",
                  "height": "70px",
                  "object-fit": "contain",
                  "border-radius": "100%"
                }
              },
              ".title-wrap": {
                ".mbr-section-title": {
                  "margin-bottom": "30px"
                }
              }
            },
