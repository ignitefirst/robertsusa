    "index.html": {
      "settings": {
        "main": true,
        "title": "How Does Robert Susa Define Success For Inventors?",
        "meta_descr": "Discover how Robert Susa defines success for inventors, emphasizing ethical guidance, structured support, and empowering creators to turn ideas into real-world solutions. Learn from his expertise and insight.",
        "header_custom": "",
        "footer_custom": "",
