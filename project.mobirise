        {
          "_name": "alist2",
          "_sourceTheme": "orderm5",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value",
              ".second-bg-color": {
                "position": "absolute",
                "top": "0",
                "left": "0",
                "width": "100%",
                "height": "100%",
                "background-color": "@secondColor",
                "border-top-left-radius": "4.1666666667vw",
                "border-top-right-radius": "4.1666666667vw"
              }
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "position": "relative",
            "& when (@reverseContent)": {
              ".row": {
                "flex-direction": "row-reverse"
              }
            },
            ".col-title": {
              "@media (max-width: 991px)": {
                "margin-bottom": "7vw"
              },
              "@media (max-width: 767px)": {
                "margin-bottom": "9vw"
              }
            },
            ".mbr-section-title": {
              "color": "#000000",
              "margin-bottom": "1rem"
            },
            ".mbr-section-subtitle": {
              "color": "#FFFFFF",
              "margin-bottom": "0"
            },
            ".toggle-panel": {
              "& when (@showListBorder)": {
                "border-top": "1px solid @listBorderColor"
              }
            },
            ".card": {
              "padding-bottom": "0",
              "border-radius": "0",
              "& when (@showListBorder)": {
                "border-bottom": "1px solid @listBorderColor"
              }
            },
            ".card-header": {
              "background-color": "transparent",
              "margin-bottom": "0",
              "padding": "0",
              "border-bottom": "none !important"
            },
            ".sign": {
              "font-family": "'Moririse2' !important",
              "padding": "10px",
              "font-size": "18px",
              "border-radius": "50%",
              "color": "@listIconColor",
              "border": "1px solid @listIconColor",
              "transition": "0.3s all",
              "animation": "icon-move-out 0.2s ease-out",
              "@media (max-width: 991px)": {
                "display": "flex",
                "align-items": "center",
                "justify-content": "center",
                "flex-shrink": "0",
                "padding": "0",
                "width": "7.3vw",
                "font-size": "3.7vw",
                "aspect-ratio": "(1 / 1)"
              },
              "@media (max-width: 767px)": {
                "width": "8.53vw",
                "font-size": "4.3vw"
              }
            },
            ".panel-title-edit": {
              "color": "#000000",
              "padding-right": "1rem",
              "transition": ".3s all"
            },
            ".panel-title": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "space-between",
              "padding": "36px 0",
              "transition": ".4s all",
              "@media (max-width: 991px)": {
                "padding": "5vw 0"
              },
              "@media (max-width: 767px)": {
                "padding": "6.4vw 0"
              },
              "&[aria-expanded=\"false\"]": {
                ".sign": {
                  "&:hover": {
                    "animation": "icon-move 0.8s forwards"
                  }
                }
              },
              "&[aria-expanded=\"true\"]": {
                ".sign": {
                  "transform": "rotate(135deg)"
                }
              }
            },
            ".panel-text": {
              "color": "#000000",
              "margin-bottom": "36px",
              "max-width": "80%",
              "width": "100%",
              "@media (max-width: 991px)": {
                "margin-bottom": "5vw",
                "max-width": "100%"
              },
              "@media (max-width: 767px)": {
                "margin-bottom": "6.4vw"
              }
            },
            "@keyframes icon-move": {
              "0%": {
                "transform": "translate3d(0, 0%, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0deg) skew(0deg, 0deg)",
                "will-change": "transform"
              },
              "80%": {
                "transform": "translate3d(0, 0%, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(360deg) skew(0deg, 0deg)"
              },
              "100%": {
                "transform": "translate3d(0, 0%, 0px) scale3d(1.2, 1.2, 1) rotateX(0deg) rotateY(0deg) rotateZ(360deg) skew(0deg, 0deg)",
                "will-change": "auto"
              }
            },
            "@keyframes icon-move-out": {
              "0%": {
                "transform": "translate3d(0, 0%, 0px) scale3d(1.2, 1.2, 1) rotateX(0deg) rotateY(0deg) rotateZ(0) skew(0deg, 0deg)",
                "will-change": "transform"
              },
              "100%": {
                "transform": "translate3d(0, 0%, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0) skew(0deg, 0deg)",
                "will-change": "auto"
              }
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"list2 orderm5\" group=\"List\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background':bg.parallax}\" plugins=\"mbr-switch-arrow, mobirise-icons2\">\n\n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"List Width\" name=\"textWidth\" min=\"5\" max=\"8\" step=\"1\" value=\"6\">\n        <input type=\"checkbox\" name=\"reverseContent\" title=\"Reverse\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n        <header>List</header>\n        <input type=\"checkbox\" title=\"Border\" name=\"showListBorder\" checked>\n        <input type=\"color\" title=\"Border Color\" name=\"listBorderColor\" value=\"#000000\" condition=\"showListBorder\">\n        <input type=\"checkbox\" title=\"Icon\" name=\"showListIcon\" checked>\n        <input type=\"color\" title=\"Icon Color\" name=\"listIconColor\" value=\"#FFFFFF\" condition=\"showListIcon\">\n        <select title=\"Amount\" name=\"cardAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\" selected>5</option>\n            <option value=\"6\">6</option>\n        </select>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/background3.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ede7e2\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@PROJECT_PATH@/assets/images/background3.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Second Bg Color\" name=\"secondBgColor\" condition=\"bg.type === 'color'\" checked>\n        <input type=\"color\" title=\"Second Color\" name=\"secondColor\" value=\"#ffffff\" condition=\"secondBgColor && bg.type === 'color'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" checked condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ede7e2\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.9\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div class=\"second-bg-color\" mbr-if=\"secondBgColor\"></div>\n    <div class=\"container\">\n            <div class=\"row justify-content-center\">\n                <div class=\"col-12 col-lg col-title\" mbr-if=\"showTitle || showSubtitle\">\n                    <h5 class=\"mbr-section-title mbr-fonts-style\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\"><b>Frequently Asked Questions?\n                    </b></h5>\n                    <h6 class=\"mbr-section-subtitle mbr-fonts-style\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-4\">\n                        Diam quam nulla porttitor massa id neque. Cursus turpis massa tincidunt dui ut ornare\n                        lectus sit amet.\n                    </h6>\n                </div>\n\n                <div class=\"col-md-12 col-lg-{{textWidth}}\">\n                    <div id=\"bootstrap-toggle\" class=\"toggle-panel accordionStyles tab-content\">\n                        <div class=\"card mb-0\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingOne\">\n                                <a role=\"button\" class=\"collapsed panel-title text-black\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse1\" aria-expanded=\"false\" aria-controls=\"collapse1\">\n                                    <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">How does Robert Susa maintain transparency while growing InventHelp?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\" mbr-if=\"showListIcon\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse1\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingOne\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Susa emphasizes clear communication, ethical decision-making, and structured support, ensuring inventors are fully informed at every stage of their journey.&nbsp;<br></p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card mb-0\" mbr-if=\"cardAmount > 1\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingTwo\">\n                                <a role=\"button\" class=\"collapsed panel-title text-black\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse2\" aria-expanded=\"false\" aria-controls=\"collapse2\">\n                                    <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">What services does InventHelp provide under Susa’s leadership?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\" mbr-if=\"showListIcon\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse2\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingTwo\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">InventHelp offers patent referrals, prototype modeling, marketing materials, and presentation preparation, all designed to guide inventors through early-stage development.&nbsp;<br></p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card mb-0\" mbr-if=\"cardAmount > 2\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingThree\">\n                                <a role=\"button\" class=\"collapsed panel-title text-black\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse3\" aria-expanded=\"false\" aria-controls=\"collapse3\">\n                                    <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">Why is ethical leadership important in the invention services industry?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\" mbr-if=\"showListIcon\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse3\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingThree\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Ethical leadership fosters trust, reduces misunderstandings, and ensures inventors can confidently pursue their ideas with professional guidance.&nbsp;<br></p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card mb-0\" mbr-if=\"cardAmount > 3\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingFour\">\n                                <a role=\"button\" class=\"collapsed panel-title text-black\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse4\" aria-expanded=\"false\" aria-controls=\"collapse4\">\n                                    <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">How does Robert Susa support education and lifelong learning?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\" mbr-if=\"showListIcon\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse4\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFour\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">He invests in scholarships and initiatives that promote creativity and knowledge, reinforcing the importance of education alongside innovation.&nbsp;<br></p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card mb-0\" mbr-if=\"cardAmount > 4\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingFive\">\n                                <a role=\"button\" class=\"collapsed panel-title text-black\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse5\" aria-expanded=\"false\" aria-controls=\"collapse5\">\n                                    <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">Can business growth and transparency coexist effectively?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\" mbr-if=\"showListIcon\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse5\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFive\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Yes, as demonstrated by Susa, combining structured support, ethical practices, and clear communication creates sustainable growth while maintaining client trust.&nbsp;<br></p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card mb-0\" mbr-if=\"cardAmount > 5\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingSix\">\n                                <a role=\"button\" class=\"collapsed panel-title text-black\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse6\" aria-expanded=\"false\" aria-controls=\"collapse6\">\n                                    <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">\n                                        PURUS NON ENIM?\n                                    </h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\" mbr-if=\"showListIcon\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse6\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingSix\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                        Erat imperdiet sed euismod nisi porta lorem mollis. Arcu vitae\n                                        elementum curabitur vitae nunc sed. Magna fermentum iaculis eu non diam. Magna\n                                        etiam tempor orci eu lobortis.\n                                    </p>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n</section>",
          "_anchor": "alist2-71",
          "_isUserblock": true,
          "_cid": "v9vmSJBAgQ",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            ".mbr-list": {
              "list-style": "none",
              "padding": "0",
              "margin": "0",
              "color": "#f4f3ee",
              "text-align": "justify"
            },
            ".copyright-section, .social-section": {
              "display": "flex",
              "flex-direction": "column",
              "justify-content": "flex-end"
            },
            ".line": {
              "margin": "10px 0",
              "width": "100%"
            },
            ".logo-section": {
              "img": {
                "margin": "0 auto"
              }
            },
            ".social-media": {
              "ul": {
                "padding": "0",
                "margin-bottom": "0",
                "li": {
                  "display": "inline-block",
                  "margin-left": "50px"
                }
              }
            },
            ".mobirise-rights": {
              "letter-spacing": ".4px"
            },
            "@media (max-width: 992px)": {
              ".social-media ul li": {
                "margin-left": "30px"
              },
              ".container-fluid": {
                "padding": "0 2rem"
              },
              ".menu-container": {
                "margin-bottom": "20px"
              },
              ".mbr-list": {
                "margin-bottom": "20px",
                "text-align": "center",
                "li": {
