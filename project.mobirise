                    }
                  },
                  ".mbr-label": {
                    "margin-bottom": "0"
                  }
                }
              },
              ".text-wrapper": {
                ".title-wrapper": {
                  ".mbr-section-title": {
                    "display": "inline-block",
                    "width": "60%",
                    "margin-bottom": "20px",
                    "@media (max-width: 992px)": {
                      "width": "100%"
                    }
                  }
                },
                ".text-wrap": {
