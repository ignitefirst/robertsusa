              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".container-fluid": {
                "padding": "0 20px",
                "@media (max-width: 992px)": {
                  "padding": "0 6px"
                }
              }
            },
            ".container": {
              "@media (max-width: 992px)": {
                "padding": "0 6px"
              }
            },
            ".row": {
              "margin": "0",
              "padding": "0 150px",
              "@media (max-width: 1440px)": {
                "padding": "0 32px"
              },
              "@media (max-width: 1200px)": {
                "padding": "0 8px"
              },
              "@media (max-width: 992px)": {
                "padding": "0 60px"
              },
              "@media (max-width: 768px)": {
                "padding": "0 30px"
              },
              ".card": {
                "padding": "0",
                "border-radius": "0 !important",
                "overflow": "visible"
              }
            },
            ".content-wrapper": {
              "display": "flex",
              "justify-content": "space-between",
              "border-bottom": "1px solid @border",
              "padding": "60px",
              "& when not (@showTitle)": {
                "justify-content": "center"
              },
              "@media (max-width: 992px)": {
                "display": "block",
                "padding": "22px"
              },
              ".title-wrapper": {
                "width": "45%",
                "padding-right": "22px",
                "& when (@reverseContent)": {
                  "padding-right": "0",
                  "padding-left": "22px",
                  "@media (max-width: 992px)": {
                    "padding": "0"
                  }
                },
                "@media (max-width: 992px)": {
                  "margin-bottom": "40px",
                  "width": "100%",
                  "padding": "0"
                },
                ".mbr-section-title": {
                  "margin-bottom": "0",
                  "opacity": ".5"
                }
              },
              ".list-wrapper": {
                "width": "55%",
                "@media (max-width: 992px)": {
                  "width": "100%"
                },
                ".list": {
                  "margin": "0",
                  "padding-left": "20px",
                  "list-style-position": "inside",
                  "@media (max-width: 992px)": {
                    "padding": "0"
                  },
                  ".item-wrap": {
                    "margin-bottom": "8px",
                    "&:last-child": {
                      "margin-bottom": "0"
                    }
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".list": {
              "color": "#131313"
            },
            ".list, .item-wrap": {
              "text-align": "left",
              "color": "#ffffff"
            }
          },
          "_cid": "v9v2DjxjKF",
