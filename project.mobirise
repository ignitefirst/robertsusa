        {
          "_name": "aarticle2",
          "_sourceTheme": "algom5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article2 algom5\" group=\"Article\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"checkbox\" name=\"reverseContent\" title=\"Reverse\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"8\" value=\"6\" step=\"1\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n        <header>Background</header>\n        <input type=\"color\" title=\"Color\" name=\"bgColor\" value=\"#0e0533\">\n    </mbr-parameters>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"main-container\">\n                <div class=\"col-12 col-lg col-title\" mbr-if=\"showTitle || showSubtitle\">\n                    <h5 class=\"mbr-section-title mbr-fonts-style\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\"><div><b>Celebrating Milestones And Continuous Growth</b></div></h5>\n                    <h6 class=\"mbr-section-subtitle mbr-fonts-style\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-5\">\n                        Ultricies mi quis hendrerit dolor magna eget.\n                    </h6>\n                </div>\n                <div class=\"col-md-12 col-lg-{{textWidth}} col-text\">\n                    <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\">Susa recognizes that success is also about celebrating milestones and embracing continuous growth. Each step an inventor takes—from conceptual sketches to prototype completion—represents progress worthy of acknowledgment. By guiding inventors to appreciate incremental achievements and encouraging ongoing learning, <a href=\"https://robert-susa.com/\" class=\"text-primary\"><b><u>Robert Susa</u></b></a> ensures that success becomes a journey rather than a destination. This perspective helps inventors remain motivated, adaptable, and prepared for the evolving challenges of their fields.&nbsp;<br></p>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "background-color": "@bgColor",
            "& when (@reverseContent)": {
              ".row": {
                "flex-direction": "row-reverse"
              }
            },
            ".main-container": {
              "display": "flex",
              "align-items": "stretch",
              "justify-content": "center",
              "padding": "0",
              "@media (max-width: 991px)": {
                "flex-wrap": "wrap",
                "padding": "0 40px"
              }
            },
            ".col-title, .col-text": {
              "display": "flex",
              "flex-direction": "column",
              "align-items": "stretch",
              "justify-content": "center",
              "padding": "10px"
            },
            ".mbr-section-title": {
              "color": "#ffffff",
              "margin-bottom": "0 !important",
              "@media (max-width: 767px)": {
                "text-align": "center !important"
              }
            },
            ".mbr-section-subtitle": {
              "color": "#112B6D",
              "margin-bottom": "0 !important",
              "margin-top": "20px",
              "@media (max-width: 767px)": {
                "text-align": "center !important"
              }
            },
            ".mbr-text": {
              "color": "#ffffff",
              "margin-bottom": "0.9rem !important",
              "@media (max-width: 767px)": {
                "text-align": "center !important"
              }
            }
          },
          "_cid": "ujl9NCqvQi",
          "_anchor": "aarticle2-8",
          "_protectedParams": [],
          "_global": false,
