                }
              }
            },
            ".container": {
              "@media (max-width: 992px)": {
                "padding": "0 20px"
              }
            },
            ".title-wrapper": {
              ".logo-wrap": {
                "margin-bottom": "30px",
                "@media (max-width: 768px)": {
