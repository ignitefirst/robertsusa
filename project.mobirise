            ".navbar-nav": {
              "margin": "auto",
              "margin-left": "0",
              "& when (@contentAlign = '2')": {
                "margin-left": "auto"
              },
              "& when (@contentAlign = '3')": {
                "margin-left": "auto",
                "margin-right": "0"
              },
              ".nav-item": {
                "padding": "0 !important",
                "transition": ".3s all !important",
                "@media (max-width: 992px)": {
                  "padding-left": "0 !important"
                },
                ".nav-link": {
                  "position": "relative",
                  "padding": "0 !important",
                  "margin": "4px 10px !important",
                  "transition": ".3s all !important",
                  "font-weight": "400",
                  "@media (max-width: 992px)": {
                    "padding": "10px 0 !important",
                    "margin-left": "0 !important"
                  },
                  "&::before": {
                    "content": "''",
                    "position": "absolute",
                    "bottom": "0",
                    "left": "0",
                    "width": "100%",
                    "height": "1px !important",
                    "background-color": "@activeColor",
                    "transform": "translateY(-2px)",
                    "opacity": "0",
                    "transition": "all 0.3s ease"
                  },
                  "&:hover": {
                    "color": "@activeColor !important",
                    "@media (max-width: 992px)": {
                      "background-color": "transparent"
                    },
                    "&::before": {
                      "transform": "translateY(0)",
                      "opacity": "1"
                    }
                  }
                }
              },
              ".open": {
                ".nav-link": {
                  "&::after": {
                    "transform": "rotate(180deg)"
                  },
                  "@media (min-width: 992px)": {
                    "&::before": {
                      "content": "\"\"",
                      "width": "100%",
                      "height": "20px",
                      "top": "100%",
                      "background": "transparent",
                      "position": "absolute"
                    }
                  }
                }
              },
              ".dropdown-item": {
                "padding": "12px !important",
                "margin": "0 8px !important",
                "transition": ".3s all !important",
                "background": "@menuBgColor",
                "font-weight": "400",
                "@media (max-width: 992px)": {
                  "margin": "0 8px 0 0 !important"
                },
                "&:hover": {
                  "color": "@activeColor"
                }
              }
            },
            ".nav-link": {
              "width": "fit-content",
              "position": "relative"
            },
            ".navbar-logo": {
              "padding-left": "0",
              "margin": "0 !important",
              "border-radius": "5px !important",
              "@media (max-width: 767px)": {
                "padding-left": "0"
              }
            },
            ".navbar-caption": {
              "padding-left": "0",
              "padding-right": "20px",
              "font-weight": "700",
              "@media (max-width: 992px)": {
                "border-right": "none"
              },
              "& when not (@showLogo)": {
                "@media (min-width: 767px)": {
                  "padding-left": "0"
                }
              },
              "&:hover": {
                "color": "@activeColor !important"
              }
            },
            ".nav-dropdown": {
