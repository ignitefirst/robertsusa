          "_name": "footer1",
          "_sourceTheme": "spiritm4",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"footer1\" group=\"Footers\" global once=\"footers\" always-bottom mbr-class=\"{'mbr-reveal': reveal, 'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"4\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"4\">\n        <input type=\"checkbox\" title=\"Reveal effect\" name=\"reveal\">\n        <input type=\"checkbox\" title=\"Show Icons\" name=\"showIcons\">\n        <input type=\"range\" inline title=\"Icons Count\" name=\"iconsCount\" min=\"1\" max=\"5\" step=\"1\" value=\"3\" condition=\"showIcons\">\n        <input type=\"range\" inline title=\"Logo Size\" name=\"imgWidth\" min=\"10\" max=\"100\" step=\"1\" value=\"10\">\n        <select title=\"Column Count\" name=\"showCard\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\" selected>4</option>\n        </select>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Background Image\" value parallax>\n            <input type=\"color\" title=\"Background Color\" value=\"#0e0533\" selected>\n        </fieldset>\n\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#f2f1eb\" condition=\"overlay&&bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay&&bg.type !== 'color'\">\n    <!-- End block parameters -->\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay&&bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div class=\"container\">\n        <div class=\"footer-container\">\n                <div class=\"row align-left menu-container\">\n            \n            <div class=\"col-lg-3 col-6\" mbr-if=\"showCard > 0\">\n                <ul mbr-text class=\"mbr-fonts-style mbr-list align-left\" mbr-theme-style=\"display-2\" data-app-selector=\".mbr-list\" data-multiline mbr-article>   \n                  <li><br></li><li><span style=\"font-size: 25.6px; letter-spacing: 0.37px;\"><a href=\"index.html\" class=\"text-primary\">Robert Susa</a></span></li> \n              </ul>\n             </div>    \n            <div class=\"col-lg-3 col-6\" mbr-if=\"showCard > 1\">\n                <ul mbr-text class=\"mbr-fonts-style mbr-list align-left\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-list\" data-multiline mbr-article>\n                  <li><b>News</b></li>\n                  <li><br></li><li><span style=\"font-size: 1.4rem;\"><a href=\"https://www.brainzmagazine.com/post/robert-susa-a-leadership-profile-rooted-in-integrity-innovation-and-opportunity\" class=\"text-primary\">Brainzmagazine</a></span></li><li><span style=\"font-size: 1.4rem;\"><a href=\"https://radaronline.com/p/robert-susa-and-inventhelp-innovation-integrity-and-opportunity-for-inventors/\" class=\"text-primary\">Radaronline</a></span></li><li><a href=\"https://www.leoweekly.com/contributor-news-2/why-inventors-trust-inventhelp/\" class=\"text-primary\">LEO Weekly</a></li><li><b><a href=\"https://www.digitaljournal.com/tech-science/inventhelp-at-ces-2026-innovation-global-opportunity-and-real-inventor-momentum/article\" class=\"text-primary\">Digital Journal&nbsp;</a></b></li><li><b><a href=\"https://markets.businessinsider.com/news/stocks/robert-susa-and-inventhelp-announce-mixaid-s-path-from-kitchen-idea-to-amazon-bestseller-1035725074\" class=\"text-primary\">Business </a></b><a href=\"https://markets.businessinsider.com/news/stocks/robert-susa-and-inventhelp-announce-mixaid-s-path-from-kitchen-idea-to-amazon-bestseller-1035725074\" class=\"text-primary\">I</a><b><a href=\"https://markets.businessinsider.com/news/stocks/robert-susa-and-inventhelp-announce-mixaid-s-path-from-kitchen-idea-to-amazon-bestseller-1035725074\" class=\"text-primary\">nsider</a></b></li><li><b><a href=\"https://finance.yahoo.com/news/robert-susa-inventhelp-announce-mixaid-174100653.html\" class=\"text-primary\">Yahoo Finance</a></b></li><li><b><a href=\"https://apnews.com/press-release/globenewswire-mobile/robert-susa-and-inventhelp-announce-mixaids-path-from-kitchen-idea-to-amazon-bestseller-0ac61c058f3f4a01ec3d5a239ec88a89\" class=\"text-primary\">AP News</a></b></li><li><b><a href=\"https://www.globenewswire.com/news-release/2026/01/19/3221214/0/en/Robert-Susa-and-InventHelp-Announce-MixAid-s-Path-From-Kitchen-Idea-to-Amazon-Bestseller.html\" class=\"text-primary\">GlobeNewswire</a></b></li><li><b><a href=\"https://www.ainvest.com/news/robert-susa-inventhelp-announce-mixaid-path-kitchen-idea-amazon-bestseller-2601/\" class=\"text-primary\">Ainvest</a></b></li><li><b><br></b></li><li><b><br></b></li>\n                </ul>\n            </div>\n            <div class=\"col-lg-3 col-6\" mbr-if=\"showCard > 2\">\n                <ul mbr-text class=\"mbr-fonts-style mbr-list align-left\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-list\" data-multiline mbr-article>\n                  <li><b>Social</b></li><li><b><br></b></li><li><a href=\"https://www.linkedin.com/in/robert-susa/\" class=\"text-primary\">LinkedIn\n</a></li><li><a href=\"https://featured.com/p/robert-susa\" class=\"text-primary\">Featured</a>\n</li><li><a href=\"https://www.crunchbase.com/person/robert-susa\" class=\"text-primary\">Crunchbase \n</a></li><li><a href=\"https://inventorsmart.com/robert-susa-president-inventhelp/\" class=\"text-primary\">Inventor Smart\n</a></li><li><a href=\"https://www.podomatic.com/podcasts/outdoorboardroom/episodes/2015-10-21T08_54_02-07_00\" class=\"text-primary\">Pedometric\n</a></li><li><a href=\"https://www.youtube.com/@RobertJSusa\" class=\"text-primary\">YouTube</a>\n</li><li><a href=\"https://medium.com/@robertjsusa\" class=\"text-primary\">Medium</a>\n</li><li><a href=\"https://medium.com/authority-magazine/robert-susa-of-inventhelp-five-things-i-wish-someone-told-me-before-i-became-a-ceo-bd467ce862f5\" class=\"text-primary\">Medium\n</a></li><li><a href=\"https://vocal.media/authors/robert-susa\" class=\"text-primary\">Vocal Media\n</a></li><li><a href=\"https://www.youtube.com/watch?v=hvnPGyqCl5E\" class=\"text-primary\">YouTube\n</a></li><li><br></li>\n                 </ul>\n            </div>\n            <div class=\"col-lg-3 col-6\" mbr-if=\"showCard > 3\">\n                <ul mbr-text class=\"mbr-fonts-style mbr-list align-left\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-list\" data-multiline mbr-article>\n                  <li><a href=\"https://www.podchaser.com/podcasts/global-economic-press-5856200/episodes/robert-susa-and-inventhelp-ann-280254441\" class=\"text-primary\"></a><b>Resources</b></li><li><b><br></b></li><li><a href=\"https://www.black-inventor.com/robert-susa\" class=\"text-primary\">Black-Inventor\n</a></li><li><a href=\"https://www.american-inventor.com/robert-susa\" class=\"text-primary\">American-Inventor \n</a></li><li><a href=\"https://www.women-inventors.com/robert-susa\" class=\"text-primary\">Women Inventors \n</a></li><li><a href=\"https://www.da-vinci-inventions.com/inventhelp-reviews\" class=\"text-primary\">Da-Vinci-Inventions \n</a></li><li><a href=\"https://global-economic-press.podbean.com/e/robert-susa-and-inventhelp-announce-mixaid-s-path-from-kitchen-idea-to-amazon-bestseller/\" class=\"text-primary\">Global Economic Press\n</a></li><li><a href=\"https://open.spotify.com/episode/6P1uY5G0rns5H6OqWHlpoy\" class=\"text-primary\">Spotify</a>\n</li><li><a href=\"https://podcasts.apple.com/us/podcast/robert-susa-and-inventhelp-announce-mixaids-path-from/id1773282513?i=1000745777308\" class=\"text-primary\">Apple Podcasts \n</a></li><li><a href=\"https://www.iheart.com/podcast/1323-global-economic-press-235116899/episode/robert-susa-and-inventhelp-announce-mixaids-318119000/\" class=\"text-primary\">iHeart\n</a></li><li><a href=\"https://www.iheart.com/podcast/1323-global-economic-press-235116899/episode/robert-susa-and-inventhelp-announce-mixaids-318119000/\" class=\"text-primary\">Podchaser\n</a></li><li><a href=\"https://podscan.fm/podcasts/global-economic-press/episodes/robert-susa-and-inventhelp-announce-mixaids-path-from-kitchen-idea-to-amazon-bestseller-bestseller\" class=\"text-primary\">Podscan.fm\n</a></li><li><br></li>\n                </ul>\n            </div>\n  \n        </div>\n        \n                <div class=\"row align-center\">\n                    <div class=\"col-12 col-md-5 copyright-section align-left\">   \n                        <hr class=\"line\">\n                        <p class=\"mbr-fonts-style mbr-text mobirise-rights mbr-semibold\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text, .copyright-section\">© Copyright 2026 - All Rights Reserved </p>\n                    </div>\n                    \n                    <div class=\"col-md-2 offset-md-0 col-6 offset-3 logo-section align-center\">\n                          \n                         \n                          \n                    </div>\n                    \n                    <div class=\"col-12 col-md-5 social-section align-right\"> \n                        <div class=\"social-media\" mbr-if=\"showIcons\">\n                             <ul>\n                   <li mbr-if=\"iconsCount > 0\">\n                       <a class=\"icon-transition\" href=\"https://www.facebook.com/GarlattiLandscaping\">\n                           <span mbr-icon class=\"mbr-iconfont socicon-facebook socicon\" style=\"color: rgb(255, 255, 255); fill: rgb(255, 255, 255);\"></span>\n                       </a>\n                   </li>\n                   <li mbr-if=\"iconsCount > 1\">\n                       <a class=\"icon-transition\" href=\"https://twitter.com/DecksFences\">\n                           <span mbr-icon class=\"mbr-iconfont socicon-twitter socicon\" style=\"color: rgb(255, 255, 255); fill: rgb(255, 255, 255);\"></span>\n                       </a>\n                   </li>\n                   <li mbr-if=\"iconsCount > 2\">\n                       <a class=\"icon-transition\" href=\"https://youtu.be/7u_90AnPDbs?si=es6_Vm-5WKPgwD_A\">\n                           <span mbr-icon class=\"mbr-iconfont socicon-youtube socicon\" style=\"color: rgb(255, 255, 255); fill: rgb(255, 255, 255);\"></span>\n                       </a>\n                   </li>\n                   <li mbr-if=\"iconsCount > 3\">\n                       <a class=\"icon-transition\" href=\"#\">\n                           <span mbr-icon class=\"mbr-iconfont socicon-youtube socicon\" style=\"color: rgb(255, 255, 255); fill: rgb(255, 255, 255);\"></span>\n                       </a>\n                   </li>\n                   <li mbr-if=\"iconsCount > 4\">\n                       <a class=\"icon-transition\" href=\"#\">\n                           <span mbr-icon class=\"mbr-iconfont socicon-rss socicon\"></span>\n                       </a>\n                   </li>\n                 </ul>\n                        </div>\n                        <hr class=\"line\">\n                        <p class=\"mbr-fonts-style mbr-text mobirise-rights mbr-semibold\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text, .copyright-section\"><a href=\"privacypolicy.html\" class=\"text-primary\">Privacy Policy</a></p>\n                </div>\n                    \n\n                 </div>\n           </div>\n    </div>\n</section>",
          "_JSplaceholders": [],
          "_PHPplaceholders": [],
          "_isUserblock": true,
          "_cid": "v9v2DteTV2",
          "_protectedParams": [],
          "_global": true,
          "_once": "footers",
          "_params": {},
          "_anchor": "footer1-6c"
        },
        {
          "_name": "alist2",
          "_sourceTheme": "orderm5",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value",
              ".second-bg-color": {
                "position": "absolute",
                "top": "0",
                "left": "0",
                "width": "100%",
                "height": "100%",
                "background-color": "@secondColor",
                "border-top-left-radius": "4.1666666667vw",
                "border-top-right-radius": "4.1666666667vw"
              }
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "position": "relative",
            "& when (@reverseContent)": {
              ".row": {
                "flex-direction": "row-reverse"
              }
            },
            ".col-title": {
              "@media (max-width: 991px)": {
                "margin-bottom": "7vw"
              },
              "@media (max-width: 767px)": {
                "margin-bottom": "9vw"
              }
            },
            ".mbr-section-title": {
              "color": "#000000",
              "margin-bottom": "1rem"
            },
            ".mbr-section-subtitle": {
              "color": "#FFFFFF",
              "margin-bottom": "0"
            },
            ".toggle-panel": {
              "& when (@showListBorder)": {
                "border-top": "1px solid @listBorderColor"
              }
            },
            ".card": {
              "padding-bottom": "0",
              "border-radius": "0",
              "& when (@showListBorder)": {
                "border-bottom": "1px solid @listBorderColor"
              }
            },
            ".card-header": {
              "background-color": "transparent",
              "margin-bottom": "0",
              "padding": "0",
              "border-bottom": "none !important"
            },
            ".sign": {
              "font-family": "'Moririse2' !important",
              "padding": "10px",
              "font-size": "18px",
              "border-radius": "50%",
              "color": "@listIconColor",
              "border": "1px solid @listIconColor",
              "transition": "0.3s all",
              "animation": "icon-move-out 0.2s ease-out",
              "@media (max-width: 991px)": {
                "display": "flex",
                "align-items": "center",
                "justify-content": "center",
                "flex-shrink": "0",
                "padding": "0",
                "width": "7.3vw",
                "font-size": "3.7vw",
                "aspect-ratio": "(1 / 1)"
              },
              "@media (max-width: 767px)": {
                "width": "8.53vw",
                "font-size": "4.3vw"
              }
            },
            ".panel-title-edit": {
              "color": "#000000",
              "padding-right": "1rem",
              "transition": ".3s all"
            },
            ".panel-title": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "space-between",
              "padding": "36px 0",
              "transition": ".4s all",
              "@media (max-width: 991px)": {
                "padding": "5vw 0"
              },
              "@media (max-width: 767px)": {
                "padding": "6.4vw 0"
              },
              "&[aria-expanded=\"false\"]": {
                ".sign": {
                  "&:hover": {
                    "animation": "icon-move 0.8s forwards"
                  }
                }
              },
              "&[aria-expanded=\"true\"]": {
                ".sign": {
                  "transform": "rotate(135deg)"
                }
              }
            },
            ".panel-text": {
              "color": "#000000",
              "margin-bottom": "36px",
              "max-width": "80%",
              "width": "100%",
              "@media (max-width: 991px)": {
                "margin-bottom": "5vw",
                "max-width": "100%"
              },
              "@media (max-width: 767px)": {
                "margin-bottom": "6.4vw"
              }
            },
            "@keyframes icon-move": {
              "0%": {
                "transform": "translate3d(0, 0%, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0deg) skew(0deg, 0deg)",
                "will-change": "transform"
              },
              "80%": {
                "transform": "translate3d(0, 0%, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(360deg) skew(0deg, 0deg)"
              },
              "100%": {
                "transform": "translate3d(0, 0%, 0px) scale3d(1.2, 1.2, 1) rotateX(0deg) rotateY(0deg) rotateZ(360deg) skew(0deg, 0deg)",
                "will-change": "auto"
              }
            },
            "@keyframes icon-move-out": {
              "0%": {
                "transform": "translate3d(0, 0%, 0px) scale3d(1.2, 1.2, 1) rotateX(0deg) rotateY(0deg) rotateZ(0) skew(0deg, 0deg)",
                "will-change": "transform"
              },
              "100%": {
                "transform": "translate3d(0, 0%, 0px) scale3d(1, 1, 1) rotateX(0deg) rotateY(0deg) rotateZ(0) skew(0deg, 0deg)",
                "will-change": "auto"
              }
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"list2 orderm5\" group=\"List\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background':bg.parallax}\" plugins=\"mbr-switch-arrow, mobirise-icons2\">\n\n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"List Width\" name=\"textWidth\" min=\"5\" max=\"8\" step=\"1\" value=\"6\">\n        <input type=\"checkbox\" name=\"reverseContent\" title=\"Reverse\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n        <header>List</header>\n        <input type=\"checkbox\" title=\"Border\" name=\"showListBorder\" checked>\n        <input type=\"color\" title=\"Border Color\" name=\"listBorderColor\" value=\"#000000\" condition=\"showListBorder\">\n        <input type=\"checkbox\" title=\"Icon\" name=\"showListIcon\" checked>\n        <input type=\"color\" title=\"Icon Color\" name=\"listIconColor\" value=\"#FFFFFF\" condition=\"showListIcon\">\n        <select title=\"Amount\" name=\"cardAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\" selected>5</option>\n            <option value=\"6\">6</option>\n        </select>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/background3.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ede7e2\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@PROJECT_PATH@/assets/images/background3.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Second Bg Color\" name=\"secondBgColor\" condition=\"bg.type === 'color'\" checked>\n        <input type=\"color\" title=\"Second Color\" name=\"secondColor\" value=\"#ffffff\" condition=\"secondBgColor && bg.type === 'color'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" checked condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ede7e2\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.9\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div class=\"second-bg-color\" mbr-if=\"secondBgColor\"></div>\n    <div class=\"container\">\n            <div class=\"row justify-content-center\">\n                <div class=\"col-12 col-lg col-title\" mbr-if=\"showTitle || showSubtitle\">\n                    <h5 class=\"mbr-section-title mbr-fonts-style\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\"><b>Frequently Asked Questions?\n                    </b></h5>\n                    <h6 class=\"mbr-section-subtitle mbr-fonts-style\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-4\">\n                        Diam quam nulla porttitor massa id neque. Cursus turpis massa tincidunt dui ut ornare\n                        lectus sit amet.\n                    </h6>\n                </div>\n\n                <div class=\"col-md-12 col-lg-{{textWidth}}\">\n                    <div id=\"bootstrap-toggle\" class=\"toggle-panel accordionStyles tab-content\">\n                        <div class=\"card mb-0\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingOne\">\n                                <a role=\"button\" class=\"collapsed panel-title text-black\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse1\" aria-expanded=\"false\" aria-controls=\"collapse1\">\n                                    <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">What sets Robert Susa apart from other business leaders?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\" mbr-if=\"showListIcon\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse1\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingOne\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Robert Susa is distinguished by his ethical approach, personalized support for inventors, and commitment to transparency and accountability, creating a leadership style that prioritizes long-term trust over short-term gains.&nbsp;<br></p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card mb-0\" mbr-if=\"cardAmount > 1\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingTwo\">\n                                <a role=\"button\" class=\"collapsed panel-title text-black\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse2\" aria-expanded=\"false\" aria-controls=\"collapse2\">\n                                    <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">How does Robert Susa support independent inventors?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\" mbr-if=\"showListIcon\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse2\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingTwo\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Through InventHelp, he provides structured assistance including patent referrals, prototype modeling, marketing materials, and strategic presentation preparation, ensuring inventors receive guidance at every step.&nbsp;<br></p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card mb-0\" mbr-if=\"cardAmount > 2\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingThree\">\n                                <a role=\"button\" class=\"collapsed panel-title text-black\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse3\" aria-expanded=\"false\" aria-controls=\"collapse3\">\n                                    <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">Why is communication important in Robert Susa’s leadership?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\" mbr-if=\"showListIcon\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse3\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingThree\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Susa emphasizes clear, transparent, and empathetic communication to build trust, encourage collaboration, and help inventors feel confident and informed throughout the process.&nbsp;<br></p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card mb-0\" mbr-if=\"cardAmount > 3\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingFour\">\n                                <a role=\"button\" class=\"collapsed panel-title text-black\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse4\" aria-expanded=\"false\" aria-controls=\"collapse4\">\n                                    <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">Does Robert Susa contribute to education initiatives?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\" mbr-if=\"showListIcon\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse4\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFour\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Yes, he actively supports scholarships and programs that promote lifelong learning, creative growth, and professional development within the invention community.&nbsp;<br></p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card mb-0\" mbr-if=\"cardAmount > 4\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingFive\">\n                                <a role=\"button\" class=\"collapsed panel-title text-black\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse5\" aria-expanded=\"false\" aria-controls=\"collapse5\">\n                                    <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">What makes Robert Susa’s leadership style unique?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\" mbr-if=\"showListIcon\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse5\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFive\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">His approach integrates professional expertise with empathy, ethical practices, and a personal investment in inventors’ success, distinguishing him from conventional executives.&nbsp;<br></p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card mb-0\" mbr-if=\"cardAmount > 5\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingSix\">\n                                <a role=\"button\" class=\"collapsed panel-title text-black\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse6\" aria-expanded=\"false\" aria-controls=\"collapse6\">\n                                    <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">\n                                        PURUS NON ENIM?\n                                    </h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\" mbr-if=\"showListIcon\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse6\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingSix\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">\n                                        Erat imperdiet sed euismod nisi porta lorem mollis. Arcu vitae\n                                        elementum curabitur vitae nunc sed. Magna fermentum iaculis eu non diam. Magna\n                                        etiam tempor orci eu lobortis.\n                                    </p>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n</section>",
          "_anchor": "alist2-70",
          "_isUserblock": true,
          "_cid": "v9vlyjKuCA",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        }
      ]
    },
    "service-expectations.html": {
      "settings": {
        "title": "How Does Robert Susa Ensure Clarity In Service Expectations?",
        "meta_descr": "Discover how Robert Susa ensures clarity in service expectations through transparent leadership, ethical engagement, and structured communication that empowers inventors to move forward with confidence.",
        "header_custom": "",
        "footer_custom": "",
        "html_before": "",
        "order": "2"
      },
      "components": [
        {
          "_name": "menu01",
          "_sourceTheme": "launchm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"menu menu01 launchm5\" group=\"Menu\" plugins=\"DropDown, TouchSwipe\" always-top global once=\"menu\" not-draggable position-absolute>\n\t<mbr-parameters>\n\t\t<header>Size</header>\n\t\t<input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n\t\t<header>Show/Hide</header>\n\t\t<input type=\"checkbox\" title=\"Logo\" name=\"showLogo\" checked>\n\t\t<input type=\"range\" title=\"Logo Size\" inline name=\"logoSize\" min=\"1\" max=\"3\" step=\"0.1\" value=\"3\" condition=\"showLogo\">\n\t\t<input type=\"checkbox\" title=\"Brand Name\" name=\"showBrand\">\n\t\t<input type=\"checkbox\" title=\"Menu Items\" name=\"showItems\" checked>\n\t\t<input type=\"color\" title=\"Active Color\" name=\"activeColor\" value=\"#ff6900\" condition=\"showItems\">\n\t\t<select title=\"Menu Items Align\" name=\"contentAlign\" condition=\"showItems\">\n\t\t\t<option value=\"1\">Left</option>\n\t\t\t<option value=\"2\" selected>Center</option>\n\t\t\t<option value=\"3\">Right</option>\n\t\t</select>\n\t\t<input type=\"checkbox\" title=\"Icons\" name=\"showIcons\">\n\t\t<select title=\"Amount\" name=\"iconsAmount\" condition=\"showIcons\">\n\t\t\t<option value=\"1\">1</option>\n\t\t\t<option value=\"2\">2</option>\n\t\t\t<option value=\"3\" selected>3</option>\n\t\t\t<option value=\"4\">4</option>\n\t\t</select>\n\t\t<input type=\"color\" title=\"Icons Color\" name=\"iconsColor\" value=\"#0f172a\" condition=\"showIcons\">\n\t\t<input type=\"checkbox\" title=\"Button\" name=\"showButtons\" checked>\n\t\t<header>Styles</header>\n\t\t<input type=\"checkbox\" title=\"Collapsed\" name=\"collapsed\" condition=\"none\">\n\t\t<input type=\"checkbox\" title=\"Transparent\" name=\"transparent\">\n\t\t<input type=\"checkbox\" title=\"Sticky\" name=\"sticky\">\n\t\t<input type=\"range\" title=\"Opacity\" name=\"opacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"transparent\">\n\t\t<input type=\"color\" title=\"Shadow 1\" value=\"#ffffff\" name=\"cardShadow_1\">\n\t\t<input type=\"color\" title=\"Shadow 2\" value=\"#0e0533\" name=\"cardShadow_2\">\n\t\t<input type=\"color\" title=\"Color\" name=\"menuBgColor\" value=\"#fafafa\">\n\t\t<input type=\"color\" title=\"Hamburger\" name=\"hamburgerColor\" value=\"#0f172a\">\n\t</mbr-parameters>\n\n\t<nav class=\"navbar navbar-dropdown\" mbr-class=\"{'navbar-fixed-top':sticky,\n                     'navbar-expand-lg':!collapsed,\n                     'collapsed':collapsed}\">\n\t\t<div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\" class=\"card-wrap\">\n\t\t\t<div class=\"navbar-brand\">\n\t\t\t\t<span mbr-if=\"showLogo\" class=\"navbar-logo\">\n\t\t\t\t\t<a href=\"https://mobiri.se\">\n\t\t\t\t\t\t<img src=\"@PROJECT_PATH@/assets/images/robert-susa-inventhelp201-407x83.png\" alt mbr-style=\"{'height': logoSize + 'rem'}\">\n\t\t\t\t\t</a>\n\t\t\t\t</span>\n\t\t\t\t<span mbr-if=\"showBrand\" mbr-buttons mbr-theme-style=\"display-7\" class=\"navbar-caption-wrap\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd,-mbrBtnRemove,-iconFont\"><a class=\"navbar-caption text-black\" data-app-selector=\".navbar-caption\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">LaunchM5</a></span>\n\t\t\t</div>\n\t\t\t<button class=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-target=\"#navbarSupportedContent\" data-bs-target=\"#navbarSupportedContent\" aria-controls=\"navbarNavAltMarkup\" aria-expanded=\"false\" aria-label=\"Toggle navigation\" mbr-if=\"showItems || showIcons || showButtons\">\n\t\t\t\t<div class=\"hamburger\">\n\t\t\t\t\t<span></span>\n\t\t\t\t\t<span></span>\n\t\t\t\t\t<span></span>\n\t\t\t\t\t<span></span>\n\t\t\t\t</div>\n\t\t\t</button>\n\t\t\t<div class=\"collapse navbar-collapse little-radius\" id=\"navbarSupportedContent\" mbr-if=\"showItems || showIcons || showButtons\">\n\t\t\t\t<ul mbr-menu class=\"navbar-nav nav-dropdown\" mbr-theme-style=\"display-4\" mbr-if=\"showItems\" mbr-class=\"{'nav-right': !showButtons,'navbar-nav-top-padding': isPublish && !showBrand && !showLogo}\"><li class=\"nav-item\">\n\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"index.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Home</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"aboutus.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" aria-expanded=\"false\">About</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"leadership-approach.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Leadership Approach</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"service-expectations.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Service Expectations</a>\n\t\t\t\t\t</li><li class=\"nav-item\"><a class=\"nav-link link text-black text-primary\" href=\"innovation-success.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Innovation Success</a></li></ul>\n\t\t\t\t<div class=\"icons-menu\" mbr-if=\"showIcons\">\n\t\t\t\t\t<a class=\"iconfont-wrapper\" href=\"https://mobiri.se\">\n\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont mobi-mbri-phone mobi-mbri\"></span>\n\t\t\t\t\t</a>\n\t\t\t\t\t<a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" mbr-if=\"iconsAmount > 1\">\n\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont mobi-mbri-letter mobi-mbri\"></span>\n\t\t\t\t\t</a>\n\t\t\t\t\t<a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" mbr-if=\"iconsAmount > 2\">\n\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont mobi-mbri-map-pin mobi-mbri\"></span>\n\t\t\t\t\t</a>\n\t\t\t\t\t<a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" mbr-if=\"iconsAmount > 3\">\n\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont mobi-mbri-shopping-cart mobi-mbri\"></span>\n\t\t\t\t\t</a>\n\t\t\t\t</div>\n\t\t\t\t<div mbr-if=\"showButtons\" mbr-buttons mbr-theme-style=\"display-4\" class=\"navbar-buttons mbr-section-btn\"><a class=\"btn btn-black\" href=\"index.html\" data-app-placeholder=\"Type Text\">\n\t\t\t\t\t\tRobert Susa\n\t\t\t\t\t</a></div>\n\t\t\t</div>\n\t\t</div>\n\t</nav>\n</section>",
          "_styles": {
            "z-index": "1000",
            "width": "100%",
            "position": "relative",
            ".dropdown-item:before": {
              "font-family": "Moririse2 !important",
              "content": "\"\\e966\"",
              "display": "inline-block",
              "width": "0",
              "position": "absolute",
              "left": "1rem",
              "top": "0.5rem",
              "margin-right": "0.5rem",
              "line-height": "1",
              "font-size": "inherit",
              "vertical-align": "middle",
              "text-align": "center",
              "overflow": "hidden",
              "transform": "scale(0, 1)",
              "transition": "all 0.25s ease-in-out"
            },
            "@media (max-width: 767px)": {
              ".navbar-toggler": {
                "transform": "scale(0.8)"
              }
            },
            ".navbar-brand": {
              "img": {
                "max-width": "100%",
                "max-height": "100%",
                "object-fit": "cover"
              },
              "flex-shrink": "0",
              "align-items": "center",
              "margin-right": "0",
              "padding": "10px 0",
              "transition": "all 0.3s",
              "word-break": "break-word",
              "z-index": "1",
              ".navbar-caption": {
                "line-height": "inherit !important"
              },
              ".navbar-logo a": {
                "outline": "none"
              }
            },
            ".navbar-nav": {
              "margin": "auto",
              "margin-left": "0",
              "& when (@contentAlign = '2')": {
                "margin-left": "auto"
              },
              "& when (@contentAlign = '3')": {
                "margin-left": "auto",
                "margin-right": "0"
              },
              ".nav-item": {
                "padding": "0 !important",
                "transition": ".3s all !important",
                "@media (max-width: 992px)": {
                  "padding-left": "0 !important"
                },
                ".nav-link": {
                  "position": "relative",
                  "padding": "0 !important",
                  "margin": "4px 10px !important",
                  "transition": ".3s all !important",
                  "font-weight": "400",
                  "@media (max-width: 992px)": {
                    "padding": "10px 0 !important",
                    "margin-left": "0 !important"
                  },
                  "&::before": {
                    "content": "''",
                    "position": "absolute",
                    "bottom": "0",
                    "left": "0",
                    "width": "100%",
                    "height": "1px !important",
                    "background-color": "@activeColor",
                    "transform": "translateY(-2px)",
                    "opacity": "0",
                    "transition": "all 0.3s ease"
                  },
                  "&:hover": {
                    "color": "@activeColor !important",
                    "@media (max-width: 992px)": {
                      "background-color": "transparent"
                    },
                    "&::before": {
                      "transform": "translateY(0)",
                      "opacity": "1"
                    }
                  }
                }
              },
              ".open": {
                ".nav-link": {
                  "&::after": {
                    "transform": "rotate(180deg)"
                  },
                  "@media (min-width: 992px)": {
                    "&::before": {
                      "content": "\"\"",
                      "width": "100%",
                      "height": "20px",
                      "top": "100%",
                      "background": "transparent",
                      "position": "absolute"
                    }
                  }
                }
              },
              ".dropdown-item": {
                "padding": "12px !important",
                "margin": "0 8px !important",
                "transition": ".3s all !important",
                "background": "@menuBgColor",
                "font-weight": "400",
                "@media (max-width: 992px)": {
                  "margin": "0 8px 0 0 !important"
                },
                "&:hover": {
                  "color": "@activeColor"
                }
              }
            },
            ".nav-link": {
              "width": "fit-content",
              "position": "relative"
            },
            ".navbar-logo": {
              "padding-left": "0",
              "margin": "0 !important",
              "border-radius": "5px !important",
              "@media (max-width: 767px)": {
                "padding-left": "0"
              }
            },
            ".navbar-caption": {
              "padding-left": "0",
              "padding-right": "20px",
              "font-weight": "700",
              "@media (max-width: 992px)": {
                "border-right": "none"
              },
              "& when not (@showLogo)": {
                "@media (min-width: 767px)": {
                  "padding-left": "0"
                }
              },
              "&:hover": {
                "color": "@activeColor !important"
              }
            },
            ".nav-dropdown": {
              "@media (max-width: 767px)": {
                "padding-bottom": "0.5rem"
              }
            },
            ".nav-dropdown .link.dropdown-toggle::after": {
              "margin-left": "0.5rem",
              "margin-top": "0rem",
              "transition": ".3s all"
            },
            ".container, .container-fluid": {
              "display": "flex",
              "min-height": "75px",
              "padding": "0 32px",
              "flex-wrap": "nowrap",
              "& when not (@collapsed)": {
                "@media (min-width: 992px)": {},
                "& when (@transparent)": {
                  "background": "rgba(red(@menuBgColor), green(@menuBgColor), blue(@menuBgColor), @opacity) !important"
                }
              },
              "left": "0",
              "right": "0",
              "-webkit-box-pack": "justify",
              "-ms-flex-pack": "justify",
              "justify-content": "flex-end",
              "-webkit-box-align": "center",
              "-webkit-align-items": "center",
              "-ms-flex-align": "center",
              "align-items": "center",
              "margin-top": ".5rem",
              "background-color": "@menuBgColor",
